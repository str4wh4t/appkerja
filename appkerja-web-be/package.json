{
  "name": "nestapi",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "build": "bun x @nestjs/cli build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "bun x @nestjs/cli start",
    "start:dev": "bun x @nestjs/cli start --watch",
    "start:debug": "bun x @nestjs/cli start --debug --watch",
    "start:prod": "bun dist/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:cov": "bun test --coverage",
    "test:debug": "bun --inspect-brk test",
    "test:e2e": "bun test",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "bun run typeorm -- migration:generate -d database/data-source.ts",
    "migration:create": "bun run typeorm -- migration:create",
    "migration:run": "bun run typeorm -- migration:run -d database/data-source.ts",
    "migration:revert": "bun run typeorm -- migration:revert -d database/data-source.ts",
    "migration:show": "bun run typeorm -- migration:show -d database/data-source.ts",
    "migration:fresh": "bun run typeorm -- schema:drop -d database/data-source.ts && bun run typeorm -- migration:run -d database/data-source.ts",
    "seed": "bun database/seeders/run-seeder.ts",
    "seed:all": "bun database/seeders/seed-all.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.3.0",
    "@as-integrations/fastify": "^3.1.0",
    "@aws-sdk/client-s3": "^3.1008.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "@nestjs/apollo": "^13.2.3",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/graphql": "^13.2.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-fastify": "^11.1.12",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/graphql-upload": "^17.0.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.8",
    "cache-manager-ioredis-yet": "^2.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "date-fns": "^4.1.0",
    "graphql": "^16.12.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-query-complexity": "^1.1.0",
    "graphql-scalars": "^1.25.0",
    "graphql-upload-ts": "^2.1.3",
    "i18n-iso-countries": "^7.14.0",
    "ioredis": "^5.10.0",
    "mysql2": "^3.16.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bun": "^1.2.23",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "overrides": {
    "lodash": "^4.17.21",
    "@apollo/server": "^5.3.0"
  }
}
