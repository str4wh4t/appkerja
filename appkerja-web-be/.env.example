# Application
NODE_ENV=development
PORT=3000
# URL publik aplikasi/API (tanpa trailing slash); prefix untuk file lokal `/uploads` di resolver GraphQL.
APP_URL=http://localhost:3000
# HTTP path untuk GraphQL (default: /graphql)
# GRAPHQL_PATH=/graphql

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=nestapi

# Redis (optional: rate limiting + cache)
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_KEY_PREFIX=nestapi:
# REDIS_CACHE_TTL_MS=300000

# Rate limiting (shared when Redis enabled)
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
# Optional override khusus endpoint auth
# AUTH_LOGIN_RATE_LIMIT_MAX=5
# AUTH_REFRESH_RATE_LIMIT_MAX=10
# AUTH_RATE_LIMIT_WINDOW_MS=60000

# Super Admin User Configuration (for seeder)
SUPERADMIN_USERNAME=
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_FIRST_NAME=
SUPERADMIN_LAST_NAME=
SUPERADMIN_EMAIL_VERIFIED=

# Upload Disk Configuration
UPLOAD_DISK=local
# Semua upload data URL (avatar, lampiran, dll.): batas ukuran dalam MB
DOCUMENT_UPLOAD_MAX_MB=3

# S3
# Endpoint untuk operasi server (upload/delete); di Docker biasanya hostname container MinIO.
S3_ENDPOINT=
# Endpoint untuk presigned URL (harus bisa dijangkau browser/host). Kosong = sama dengan S3_ENDPOINT.
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
# Bucket untuk objek publik (upload saat isPublicUpload=true). Wajib berbeda dari S3_BUCKET jika UPLOAD_DISK=s3.
S3_PUBLIC_BUCKET=
S3_REGION=
# TTL presigned URL download (detik), default 900 (15 menit)
S3_PRESIGNED_EXPIRES_IN_SECONDS=900

FRONTEND_URL_LOGIN=http://localhost:4000/login

# Tenancy
DEFAULT_TENANT_CODE=default

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_STATE_SECRET=
GOOGLE_STATE_EXPIRES_IN=10m
GOOGLE_LOGIN_CODE_EXPIRES_IN_MS=60000
