# Copy to .env and adjust. Used by docker compose.

COMPOSE_PROJECT_NAME=appkerja-storage

# MinIO root credentials (S3 access key / secret for admin)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production

# S3 "region" label for this MinIO site (use the same value in BE AWS SDK / S3 client).
# Common: us-east-1. You can use e.g. ap-southeast-1 for naming only — it is not tied to AWS.
MINIO_SITE_REGION=us-east-1

# Buckets created once by minio-init (idempotent)
MINIO_DEFAULT_BUCKET=appkerja-documents
# Aset publik (atur policy/CORS di Console atau mc sesuai kebutuhan)
MINIO_PUBLIC_BUCKET=appkerja-public-documents

# Host ports (API S3-compatible, Web console)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
